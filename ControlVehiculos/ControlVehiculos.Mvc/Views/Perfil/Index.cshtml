@model IEnumerable<ControlVehiculos.Mvc.Models.VehiculoViewModel>
@{
    ViewData["Title"] = "Mi Perfil";
    var stats = ViewBag.Estadisticas as EstadisticasTrabajadorViewModel;
}

<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h1 class="fw-bold text-primary">Mi Perfil Profesional</h1>
        <p class="text-muted">Gestión de rendimiento individual en el sistema.</p>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Columna Izquierda: Información de Usuario -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center p-5">
                <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 100px; height: 100px;">
                    <i class="bi bi-person-fill" style="font-size: 3.5rem;"></i>
                </div>
                <h3 class="fw-bold mb-2">@ViewBag.TrabajadorNombre</h3>
                <span class="badge bg-secondary px-3 py-2 rounded-pill mb-3">Socio de Ventas</span>
                <p class="text-muted mb-0"><i class="bi bi-geo-alt-fill text-danger"></i> Sede: @ViewBag.TrabajadorPais</p>
            </div>
        </div>
    </div>

    <!-- Columna Derecha: Tarjetas Métricas (KPIs desde tu SP Analítico) -->
    <div class="col-md-8">
        <div class="row g-3 h-100">
            <div class="col-sm-6">
                <div class="card border-0 shadow-sm h-100 bg-light">
                    <div class="card-body d-flex align-items-center">
                        <div class="bg-primary text-white p-3 rounded-3 me-3">
                            <i class="bi bi-car-front-fill fs-2"></i>
                        </div>
                        <div>
                            <span class="text-muted small d-block">Total Registrados</span>
                            <h3 class="fw-bold mb-0">@stats?.TotalRegistrados</h3>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6">
                <div class="card border-0 shadow-sm h-100 bg-light">
                    <div class="card-body d-flex align-items-center">
                        <div class="bg-success text-white p-3 rounded-3 me-3">
                            <i class="bi bi-tag-fill fs-2"></i>
                        </div>
                        <div>
                            <span class="text-muted small d-block">En Venta Activos</span>
                            <h3 class="fw-bold mb-0 text-success">@stats?.TotalEnVenta</h3>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6">
                <div class="card border-0 shadow-sm h-100 bg-light">
                    <div class="card-body d-flex align-items-center">
                        <div class="bg-danger text-white p-3 rounded-3 me-3">
                            <i class="bi bi-check-circle-fill fs-2"></i>
                        </div>
                        <div>
                            <span class="text-muted small d-block">Vehículos Vendidos</span>
                            <h3 class="fw-bold mb-0 text-danger">@stats?.TotalVendidos</h3>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6">
                <div class="card border-0 shadow-sm h-100 bg-light">
                    <div class="card-body d-flex align-items-center">
                        <div class="bg-warning text-dark p-3 rounded-3 me-3">
                            <i class="bi bi-currency-dollar fs-2"></i>
                        </div>
                        <div>
                            <span class="text-muted small d-block">Ganancia Generada</span>
                            <h3 class="fw-bold mb-0 text-dark">@stats?.GananciaTotalGenerada.ToString("C")</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- LISTADO PERSONAL DE AUTOS REGISTRADOS -->
<h3 class="fw-bold mb-4 text-muted">Vehículos que he registrado</h3>
<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Marca</th>
                    <th>Color</th>
                    <th>Modelo (Año)</th>
                    <th>Precio Compra</th>
                    <th>Precio Reventa</th>
                    <th>Disponibilidad</th>
                    <th>Condición Física</th>
                    <th class="text-center">Acción</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">Aún no has registrado ningún vehículo en el sistema.</td>
                    </tr>
                }
                @foreach (var auto in Model)
                {
                    <tr>
                        <td class="fw-bold">@auto.Marca</td>
                        <td>@auto.Color</td>
                        <td>@auto.ModeloAnio</td>
                        <td>@auto.PrecioCompra.ToString("C")</td>
                        <td class="text-success fw-bold">@auto.PrecioReventa?.ToString("C")</td>
                        <td>
                            @if (auto.Vendido)
                            {
                                <span class="badge bg-danger rounded-pill">Vendido</span>
                            }
                            else
                            {
                                <span class="badge bg-success rounded-pill">En Venta</span>
                            }
                        </td>
                        <td><span class="badge bg-secondary">@auto.EstadoFisico</span></td>
                        <td class="text-center">
                            <a asp-controller="Home" asp-action="Detalle" asp-route-id="@auto.Id" class="btn btn-sm btn-outline-primary rounded-pill">Ver Ficha</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>